# --- Vaultwarden ---
# Generate with: openssl rand -base64 48
ADMIN_TOKEN=replace-me
# Set to true only briefly to create your account, then false.
SIGNUPS_ALLOWED=false
LOG_LEVEL=warn

# --- Cloudflare Tunnel ---
# From the Cloudflare Zero Trust dashboard (Networks -> Tunnels -> connector token)
CLOUDFLARE_TUNNEL_TOKEN=replace-me

# --- Cloudflare R2 (S3-compatible) ---
# Account ID lives in your Cloudflare dashboard URL.
R2_BUCKET=vaultwarden-backup
R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=replace-me
R2_SECRET_ACCESS_KEY=replace-me
